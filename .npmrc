# EasyTerm npm 配置
#
# 仅设置二进制下载镜像,不修改 registry。理由:
# - electron / electron-builder 的二进制从 GitHub Releases 下载,
#   在国内网络下经常 ECONNRESET,镜像到 npmmirror 几乎必成功
# - npm registry 不动,避免覆盖开发者自己的 .npmrc 偏好
#   (例如已配置的私有 registry 或别的镜像)
#
# 对应文档: AGENTS.md 附录 B "npm install 失败怎么办"

electron_mirror=https://npmmirror.com/mirrors/electron/
electron_builder_binaries_mirror=https://npmmirror.com/mirrors/electron-builder-binaries/

# 可选: node-pty 等 native 模块的预编译二进制下载源
# (V1 只 Windows,prebuild 通常存在;若失败会 fallback 到本地编译)
prebuild_binary_host_mirror=https://npmmirror.com/mirrors/
